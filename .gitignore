# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
.pm2/
# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/lib/generated/prisma

# Database files (SQLite)
*.db
*.db-journal
*.db-wal
*.db-shm
prisma/dev.db

# logs
/logs
*.log

# pm2
/.pm2

# Local IDE configuration
.vscode/
.idea/
*.swp
*.swo
*~

# Temporary data files
app/dashboard/data.json

# Lock files - keep only one depending on package manager used
# If using npm, uncomment the next line
# package-lock.json
# If using bun, uncomment the next line
# bun.lock

# Local development files
*.local
.DS_Store?
logs/combined.log
logs/error.log
